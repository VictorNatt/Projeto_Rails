<h1>Blog Simples</h1>

<!-- Formulário para criar post -->
<div class="card">
  <%= form_with model: @post, url: posts_path, local: true do |f| %>
    <p><%= f.label :title, "Título" %><br>
       <%= f.text_field :title %></p>

    <p><%= f.label :author, "Autor" %><br>
       <%= f.text_field :author %></p>

    <p><%= f.label :content, "Conteúdo" %><br>
       <%= f.text_area :content %></p>

    <p><%= f.submit "Publicar" %></p>
  <% end %>
</div>

<h1>Lista de Posts</h1>

<% @posts.each do |post| %>
  <div class="post">
    <h2><%= post.title %></h2>
    <p><strong>Autor:</strong> <%= post.author %></p>
    <p><%= post.content %></p>

    <div class="actions">
      <%= link_to 'Excluir', post_path(post), 
            data: { turbo_method: :delete, turbo_confirm: 'Tem certeza que deseja excluir este post?' },
            class: 'delete' %>
    </div>
  </div>
<% end %>

